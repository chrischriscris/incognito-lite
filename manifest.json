{
  "manifest_version": 2,
  "name": "Incognito Lite",
  "version": "1.0.0",
  "description": "Temporarily auto-removes visited pages from local browser history while enabled.",
  "permissions": [
    "history",
    "storage",
    "tabs",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon-unpaused.svg",
    "96": "icons/icon-unpaused.svg"
  },
  "browser_action": {
    "default_title": "Incognito Lite",
    "default_icon": "icons/icon-unpaused.svg",
    "default_area": "navbar"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "incognito-lite@example.local",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
