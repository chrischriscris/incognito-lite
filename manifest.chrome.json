{
  "manifest_version": 3,
  "name": "Incognito Lite",
  "version": "1.0.0",
  "description": "Temporarily auto-removes visited pages from local browser history while enabled.",
  "permissions": [
    "history",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-unpaused-16.png",
    "32": "icons/icon-unpaused-32.png",
    "48": "icons/icon-unpaused-48.png",
    "128": "icons/icon-unpaused-128.png"
  },
  "action": {
    "default_title": "Incognito Lite",
    "default_icon": {
      "16": "icons/icon-unpaused-16.png",
      "32": "icons/icon-unpaused-32.png",
      "48": "icons/icon-unpaused-48.png",
      "128": "icons/icon-unpaused-128.png"
    }
  }
}
